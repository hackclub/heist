# .env.development.example
# Example environment variables for local development

DATABASE_URL=postgresql://postgres:starter@localhost:5432/hc_rails_starter_development

# HCA OAuth
HCA_CLIENT_ID=
HCA_CLIENT_SECRET=

# Active Record encryption (generate via: bin/rails db:encryption:init)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Slack bot token for profile sync
SLACK_BOT_TOKEN=

# Geocoding API (Hack Club service)
GEOCODER_API_KEY=

# External API key for /api/v1 endpoints
EXTERNAL_API_KEY=dev_api_key

# Optional: URL to ping for uptime monitoring (leave empty if not using)
# UPTIME_WORKER_PING_URL=

# Ferret semantic search service
FERRET_URL=http://localhost:4567

# Honeycomb observability (OpenTelemetry) — optional for local dev
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=
# OTEL_SERVICE_NAME=heist-development
