<% content_for :title, "HOME — The Heist" %>
<% content_for :sidebar_active, :home %>

<%
  fmt_hm = ->(total_seconds) {
    s = total_seconds.to_i
    h = s / 3600
    m = (s % 3600) / 60
    "#{h}h #{m}m"
  }
%>

<div class="heist-home">
  <div class="heist-home__main">

    <section class="heist-top-panel">
      <div class="heist-top-panel__hours">
        <p class="heist-top-panel__label">Total Hours Shipped (Week <%= @week_number %>)</p>
        <div class="heist-progress" role="progressbar"
             aria-valuenow="<%= @hours_shipped %>" aria-valuemin="0" aria-valuemax="<%= @hour_goal %>">
          <% @ship_segments.each_with_index do |seg, idx| %>
            <span class="heist-progress__seg-wrap"
                  style="left: <%= seg[:offset_pct].round(4) %>%; width: <%= seg[:width_pct].round(4) %>%;"
                  data-controller="ship-tooltip">
              <button type="button" class="heist-progress__segment <%= 'heist-progress__segment--alt' if idx.odd? %>"
                      aria-describedby="ship-tooltip-<%= seg[:ship].id %>"
                      data-action="click->ship-tooltip#toggle">
                <span class="heist-progress__segment-sr"><%= seg[:user].display_name.to_s %> shipped <%= fmt_hm.call(seg[:ship_seconds]) %></span>
              </button>
              <span id="ship-tooltip-<%= seg[:ship].id %>" class="heist-progress__tooltip" role="tooltip"
                    data-ship-tooltip-target="tooltip">
                <span class="heist-progress__tooltip-connector" aria-hidden="true"></span>
                <span class="heist-progress__tooltip-header"><%= fmt_hm.call(seg[:ship_seconds]) %> shipped</span>
                <span class="heist-progress__tooltip-identity">
                  <%= image_tag seg[:user].avatar_url, class: "heist-progress__tooltip-avatar", alt: "" %>
                  <span class="heist-progress__tooltip-name"><%= seg[:user].display_name.to_s.downcase %></span>
                </span>
                <span class="heist-progress__tooltip-stats">
                  <%= pluralize(seg[:user_project_count], "project") %> &middot; <%= fmt_hm.call(seg[:user_total_shipped_seconds]) %> shipped
                </span>
                <% if seg[:user_recent_projects].any? %>
                  <span class="heist-progress__tooltip-projects">
                    <% seg[:user_recent_projects].each do |project| %>
                      <%= link_to project_path(project), class: "heist-progress__tooltip-project" do %>
                        <span class="heist-progress__tooltip-cover" aria-hidden="true">
                          <span class="heist-progress__tooltip-cover-letter"><%= project.name.to_s.first.to_s.upcase %></span>
                        </span>
                        <span class="heist-progress__tooltip-project-meta">
                          <span class="heist-progress__tooltip-project-name"><%= project.name.to_s.downcase %></span>
                          <span class="heist-progress__tooltip-project-desc"><%= truncate(project.description.to_s, length: 30) %></span>
                        </span>
                      <% end %>
                    <% end %>
                  </span>
                <% end %>
              </span>
            </span>
          <% end %>
          <span class="heist-progress__label"><%= @hours_shipped %> hrs / <%= number_with_delimiter(@hour_goal) %> hrs</span>
        </div>
      </div>

      <div class="heist-top-panel__countdown"
           data-controller="countdown"
           data-countdown-target-value="<%= @week_ends_at.iso8601 %>">
        <p class="heist-top-panel__label heist-top-panel__label--amber">Week <%= @week_number %> hour left</p>
        <p class="heist-countdown">
          <span data-countdown-target="days">--</span>d
          <span data-countdown-target="hours">--</span>h
          <span data-countdown-target="minutes">--</span>m
          <span data-countdown-target="seconds">--</span>s
        </p>
      </div>
    </section>

    <div class="heist-home__mid-row">
      <section class="heist-panel heist-panel--bulletin">
        <header class="heist-panel__header"><span>Bulletin board</span></header>
        <div class="heist-panel__body heist-bulletin">
          <% if @bulletin_posts.any? %>
            <% @bulletin_posts.each do |post| %>
              <article class="heist-bulletin__post">
                <h3 class="heist-bulletin__title"><%= post.title %></h3>
                <div class="heist-bulletin__body"><%= simple_format(post.body) %></div>
                <p class="heist-bulletin__meta">Posted on <%= post.posted_at.to_date.strftime("%m/%d/%Y") %></p>
              </article>
            <% end %>
          <% else %>
            <article class="heist-bulletin__post heist-bulletin__post--placeholder" aria-label="Placeholder bulletin post">
              <h3 class="heist-bulletin__title">Welcome hackers!</h3>
              <div class="heist-bulletin__body">
                <p>Today is the start of The Heist Weekend 1! The plan is simple: watch the streams, code, ship your project, and steal prizes!</p>
              </div>
              <p class="heist-bulletin__meta">Posted on 05/01/2026</p>
            </article>
          <% end %>
        </div>
      </section>

      <section class="heist-panel heist-panel--partners">
        <header class="heist-panel__header"><span>Partners in crime</span></header>
        <div class="heist-panel__body heist-partners">
          <% if @activity.any? %>
            <% @activity.each do |entry| %>
              <% if entry[:kind] == :ship %>
                <% ship = entry[:record] %>
                <% project = ship.project %>
                <% user = project.user %>
                <% seconds = ship.approved_seconds.to_i %>
                <article class="heist-partners__item">
                  <%= image_tag user.avatar_url, class: "heist-partners__avatar", alt: "" %>
                  <div class="heist-partners__content">
                    <h3 class="heist-partners__title">
                      <%= user.display_name.to_s.downcase %> shipped <%= fmt_hm.call(seconds) %> from <%= project.name.to_s.downcase %>
                    </h3>
                    <p class="heist-partners__body"><%= truncate(project.description.to_s, length: 180) %></p>
                    <div class="heist-partners__footer">
                      <span class="heist-partners__time"><%= time_ago_in_words(entry[:at]) %> ago</span>
                      <div class="heist-partners__links">
                        <% if ship.frozen_repo_link.present? %>
                          <%= link_to ship.frozen_repo_link, class: "heist-partners__link", target: "_blank", rel: "noopener" do %>
                            <span aria-hidden="true">◈</span>REPO
                          <% end %>
                        <% end %>
                        <% if ship.frozen_demo_link.present? %>
                          <%= link_to ship.frozen_demo_link, class: "heist-partners__link", target: "_blank", rel: "noopener" do %>
                            <span aria-hidden="true">↗</span>DEMO
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </article>
              <% else %>
                <% project = entry[:record] %>
                <% user = project.user %>
                <article class="heist-partners__item">
                  <%= image_tag user.avatar_url, class: "heist-partners__avatar", alt: "" %>
                  <div class="heist-partners__content">
                    <h3 class="heist-partners__title">
                      <%= user.display_name.to_s.downcase %> created a project: <%= project.name.to_s.downcase %>
                    </h3>
                    <p class="heist-partners__body"><%= truncate(project.description.to_s, length: 180) %></p>
                    <div class="heist-partners__footer">
                      <span class="heist-partners__time"><%= time_ago_in_words(entry[:at]) %> ago</span>
                      <div class="heist-partners__links">
                        <% if project.repo_link.present? %>
                          <%= link_to project.repo_link, class: "heist-partners__link", target: "_blank", rel: "noopener" do %>
                            <span aria-hidden="true">◈</span>REPO
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </article>
              <% end %>
            <% end %>
          <% else %>
            <p class="heist-partners__empty">No activity yet. Be the first to ship a project.</p>
          <% end %>
        </div>
      </section>
    </div>

    <section class="heist-panel heist-panel--projects">
      <header class="heist-panel__header heist-panel__header--split">
        <span class="heist-panel__header-title">Projects</span>
        <span class="heist-panel__header-stat heist-panel__header-stat--logged"><%= fmt_hm.call(@user_logged_seconds) %> logged time</span>
        <span class="heist-panel__header-stat heist-panel__header-stat--shipped"><%= fmt_hm.call(@user_shipped_seconds) %> shipped time</span>
      </header>
      <div class="heist-panel__body heist-projects">
        <% if policy(Project).create? %>
          <% create_path = current_user.projects.kept.empty? ? onboarding_projects_path : new_project_path %>
          <%= link_to create_path, class: "heist-project heist-project--new" do %>
            <span class="heist-project__plus" aria-hidden="true">+</span>
            <span class="heist-project__label">Create a project</span>
          <% end %>
        <% end %>
        <% @projects.each do |project| %>
          <%= link_to project_path(project), class: "heist-project" do %>
            <h3 class="heist-project__name"><%= project.name.to_s.downcase %></h3>
            <p class="heist-project__desc"><%= truncate(project.description.to_s, length: 120) %></p>
            <% total_seconds = @project_shipped_seconds[project.id].to_i %>
            <% if total_seconds.positive? %>
              <p class="heist-project__time">
                <span class="heist-project__clock" aria-hidden="true">◷</span>
                <%= fmt_hm.call(total_seconds) %>
              </p>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>
</div>

<style>
  .heist-home {
    --heist-bg: #0E1A10;
    --heist-bg-2: #0A1309;
    --heist-grid: rgba(90, 180, 96, 0.08);
    --heist-lime: #C0F477;
    --heist-lime-soft: #DAFBAC;
    --heist-amber: #FFE572;
    --heist-amber-dim: #DBC45F;
    --heist-ink: #14251C;
    --heist-stripe-amber: repeating-linear-gradient(135deg, rgba(255, 229, 114, 0.13) 0 6px, transparent 6px 12px);
    --heist-stripe-lime: repeating-linear-gradient(135deg, rgba(192, 244, 119, 0.14) 0 6px, transparent 6px 12px);

    color: var(--heist-lime);
    font-family: "ModeSeven", ui-monospace, "SFMono-Regular", Menlo, monospace;
  }

  .heist-home__main {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 8px;
  }

  .heist-home__mid-row .heist-panel {
    display: flex;
    flex-direction: column;
    min-height: 0;
    max-height: 360px;
  }

  .heist-home__mid-row .heist-panel__body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }

  .heist-top-panel {
    position: relative;
    z-index: 50;
    display: grid;
    grid-template-columns: minmax(0, 2.2fr) minmax(0, 1fr);
    gap: 4px;
    margin-bottom: 0;
  }

  .heist-top-panel__hours {
    padding: 0.7rem 1rem;
    border: 4px solid var(--heist-lime);
    border-radius: 4px;
    background:
      var(--heist-stripe-lime),
      rgba(10, 19, 9, 0.55);
    box-shadow: 0 0 18px rgba(192, 244, 119, 0.15);
  }

  .heist-top-panel__countdown {
    padding: 0.7rem 1rem;
    border: 4px solid var(--heist-amber-dim);
    border-radius: 4px;
    background:
      var(--heist-stripe-amber),
      rgba(20, 37, 28, 0.5);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
  }

  .heist-top-panel__label {
    margin: 0 0 0.5rem;
    font-family: "Blade Runner", "ModeSeven", ui-monospace, monospace;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--heist-lime);
    text-shadow: 0 0 4px rgba(192, 244, 119, 0.35);
  }

  .heist-top-panel__label--amber {
    color: var(--heist-amber-dim);
    text-shadow: 0 0 4px rgba(219, 196, 95, 0.35);
  }

  .heist-home__mid-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4px;
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .heist-top-panel,
    .heist-home__mid-row { grid-template-columns: minmax(0, 1fr); }
  }

  .heist-panel {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 4px;
    background: rgba(20, 37, 28, 0.55);
    border: 4px solid var(--heist-amber-dim);
    box-shadow: none;
    overflow: hidden;
  }

  .heist-panel__header {
    padding: 0.5rem 0.9rem;
    font-family: "Blade Runner", "ModeSeven", ui-monospace, monospace;
    font-size: 16px;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 0.04em;
    color: var(--heist-amber);
    text-shadow: 0 0 4px rgba(255, 229, 114, 0.35);
    background:
      var(--heist-stripe-amber),
      rgba(10, 19, 9, 0.55);
    border: 4px solid var(--heist-amber-dim);
    border-radius: 2px;
    text-transform: lowercase;
  }

  .heist-top-panel .heist-progress {
    height: 2.9rem;
    border: 3px solid var(--heist-lime);
    background:
      repeating-linear-gradient(135deg, rgba(192, 244, 119, 0.08) 0 6px, transparent 6px 12px),
      rgba(14, 40, 18, 0.55);
    overflow: visible;
  }

  .heist-top-panel .heist-progress__label {
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 18px;
    color: var(--heist-lime);
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.95);
    letter-spacing: 0.02em;
  }

  .heist-progress__seg-wrap {
    position: absolute;
    top: 0;
    bottom: 0;
    display: block;
    min-width: 6px;
    pointer-events: auto;
  }

  .heist-progress__seg-wrap:hover,
  .heist-progress__seg-wrap:focus-within,
  .heist-progress__seg-wrap.is-pinned { z-index: 70; }

  .heist-progress__segment {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    cursor: pointer;
    background:
      /* per-bar vertical separators: thin amber-dim gap every ~16px */
      repeating-linear-gradient(
        90deg,
        transparent 0 13px,
        rgba(219, 196, 95, 0.85) 13px 16px
      ),
      /* diagonal hatch inside each tally bar */
      repeating-linear-gradient(
        135deg,
        rgba(219, 196, 95, 0.55) 0 3px,
        transparent 3px 7px
      ),
      rgba(255, 229, 114, 0.95);
    box-shadow: 0 0 8px rgba(255, 229, 114, 0.35);
    transition: filter 150ms ease;
  }

  .heist-progress__segment--alt {
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0 13px,
        rgba(255, 229, 114, 0.85) 13px 16px
      ),
      repeating-linear-gradient(
        135deg,
        rgba(255, 229, 114, 0.55) 0 3px,
        transparent 3px 7px
      ),
      rgba(219, 196, 95, 0.95);
    box-shadow: 0 0 8px rgba(219, 196, 95, 0.35);
  }

  .heist-progress__segment:hover,
  .heist-progress__segment:focus-visible {
    filter: brightness(1.5);
    outline: 2px solid var(--heist-amber);
    outline-offset: -2px;
    z-index: 2;
  }

  .heist-progress__segment-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .heist-progress__tooltip {
    position: absolute;
    top: calc(100% + 14px);
    left: 0;
    transform: translateX(-14px) translateY(-4px);
    width: 300px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    gap: 4px;
    padding: 4px;
    border: 4px solid var(--heist-amber-dim);
    background:
      var(--heist-stripe-lime),
      rgba(20, 37, 28, 0.92);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.7);
    text-align: left;
    transition:
      opacity 140ms ease,
      transform 140ms ease,
      visibility 0s linear 200ms;
  }

  /* invisible bridge between bar and tooltip so the cursor can cross the gap
     without losing hover; also stops a flicker when sliding between segments */
  .heist-progress__tooltip::before {
    content: "";
    position: absolute;
    top: -18px;
    left: 0;
    right: 0;
    height: 18px;
  }

  .heist-progress__seg-wrap:hover .heist-progress__tooltip,
  .heist-progress__seg-wrap:focus-within .heist-progress__tooltip,
  .heist-progress__seg-wrap.is-pinned .heist-progress__tooltip,
  .heist-progress__tooltip:hover {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-14px) translateY(0);
    transition:
      opacity 140ms ease,
      transform 140ms ease,
      visibility 0s linear 0s;
  }

  /* flipped variant: tooltip anchors to seg-wrap's right edge for late segments */
  .heist-progress__tooltip.is-flipped {
    left: auto;
    right: 0;
    transform: translateX(14px) translateY(-4px);
  }

  .heist-progress__seg-wrap:hover .heist-progress__tooltip.is-flipped,
  .heist-progress__seg-wrap:focus-within .heist-progress__tooltip.is-flipped,
  .heist-progress__seg-wrap.is-pinned .heist-progress__tooltip.is-flipped,
  .heist-progress__tooltip.is-flipped:hover {
    transform: translateX(14px) translateY(0);
  }

  .heist-progress__tooltip-connector {
    position: absolute;
    bottom: 100%;
    left: 14px;
    width: 14px;
    height: 18px;
    background: var(--heist-amber);
    border: 2px solid var(--heist-amber-dim);
    box-shadow: 0 0 8px rgba(255, 229, 114, 0.6);
  }

  .heist-progress__tooltip.is-flipped .heist-progress__tooltip-connector {
    left: auto;
    right: 14px;
  }

  .heist-progress__tooltip-header {
    display: block;
    padding: 0.5rem 0.9rem;
    border: 4px solid var(--heist-amber-dim);
    border-radius: 2px;
    background:
      var(--heist-stripe-amber),
      rgba(10, 19, 9, 0.7);
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 12px;
    color: var(--heist-amber);
    text-shadow: 0 0 4px rgba(255, 229, 114, 0.35);
    text-align: center;
    letter-spacing: 0.04em;
  }

  .heist-progress__tooltip-identity {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 10px;
    padding: 8px 12px 0;
  }

  .heist-progress__tooltip-avatar {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(255, 229, 114, 0.45);
    background: rgba(14, 40, 18, 0.7);
  }

  .heist-progress__tooltip-name {
    font-family: "Blade Runner", "ModeSeven", ui-monospace, monospace;
    font-size: 22px;
    color: var(--heist-lime);
    text-shadow: 0 0 4px rgba(192, 244, 119, 0.4);
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  .heist-progress__tooltip-stats {
    display: block;
    padding: 0 12px 8px;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 12px;
    color: var(--heist-amber);
    letter-spacing: 0.04em;
  }

  .heist-progress__tooltip-projects {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4px;
  }

  .heist-progress__tooltip-project {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr);
    gap: 8px;
    align-items: center;
    padding: 4px;
    border: 4px solid var(--heist-amber-dim);
    background:
      var(--heist-stripe-amber),
      rgba(10, 19, 9, 0.55);
    text-decoration: none;
    color: inherit;
    transition: background 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  }

  a.heist-progress__tooltip-project:hover,
  a.heist-progress__tooltip-project:focus-visible {
    background:
      var(--heist-stripe-amber),
      rgba(20, 37, 28, 0.85);
    box-shadow: 0 0 12px rgba(255, 229, 114, 0.35);
    outline: none;
  }

  a.heist-progress__tooltip-project:focus-visible {
    outline: 2px solid var(--heist-amber);
    outline-offset: 1px;
  }

  .heist-progress__tooltip-cover {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--heist-amber-dim);
    background:
      repeating-linear-gradient(135deg, rgba(192,244,119,0.45) 0 4px, rgba(20,37,28,0.85) 4px 8px),
      rgba(14,40,18,0.85);
  }

  .heist-progress__tooltip-cover-letter {
    font-family: "Blade Runner", "ModeSeven", ui-monospace, monospace;
    font-size: 18px;
    color: var(--heist-amber);
    text-shadow: 0 0 4px rgba(0, 0, 0, 0.85);
  }

  .heist-progress__tooltip-project-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .heist-progress__tooltip-project-name {
    font-family: "Blade Runner", "ModeSeven", ui-monospace, monospace;
    font-size: 14px;
    color: var(--heist-lime);
    letter-spacing: 0.02em;
    text-transform: lowercase;
    text-shadow: 0 0 4px rgba(192, 244, 119, 0.35);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .heist-progress__tooltip-project-desc {
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 10px;
    line-height: 1.2;
    color: var(--heist-amber);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* gentle dim of nearby panels so the tooltip reads cleanly without blacking
     out the whole dashboard. Header, sidebar, and countdown stay full opacity. */
  .heist-home:has(.heist-progress__segment:hover) .heist-home__mid-row,
  .heist-home:has(.heist-progress__segment:focus-visible) .heist-home__mid-row,
  .heist-home:has(.heist-progress__seg-wrap.is-pinned) .heist-home__mid-row {
    opacity: 0.55;
    transition: opacity 200ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .heist-home__mid-row,
    .heist-progress__segment,
    .heist-progress__tooltip,
    .heist-progress__tooltip-project {
      transition: none;
    }
    .heist-progress__tooltip,
    .heist-progress__tooltip.is-flipped {
      transform: translateX(-14px);
    }
    .heist-progress__tooltip.is-flipped {
      transform: translateX(14px);
    }
  }

  .heist-panel__header--split {
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 0;
    text-transform: none;
    display: flex;
    align-items: stretch;
    gap: 4px;
  }

  .heist-panel__header--split > .heist-panel__header-title,
