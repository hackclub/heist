<%# Identity chip for page headers. Avatar + name + email + role badge + signout icon. Renders nothing if signed out. %>
<% if current_user %>
  <div class="heist-identity" title="<%= current_user.email %>">
    <%= image_tag current_user.avatar_url, class: "heist-identity__avatar", alt: "" %>
    <span class="heist-identity__meta">
      <span class="heist-identity__name"><%= current_user.display_name %></span>
      <span class="heist-identity__email"><%= current_user.email %></span>
    </span>
    <% if current_user.admin? %>
      <span class="heist-identity__role heist-identity__role--admin">ADMIN</span>
    <% elsif current_user.reviewer? %>
      <span class="heist-identity__role heist-identity__role--reviewer">STAFF</span>
    <% end %>
    <%= button_to signout_path, method: :delete, class: "heist-identity__signout", form: { class: "heist-identity__signout-form" }, title: "Sign out", "aria-label": "Sign out" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="miter" stroke-linecap="square" aria-hidden="true">
        <path d="M10 4H4v16h6"/>
        <path d="M14 8l4 4-4 4"/>
        <path d="M18 12H8"/>
      </svg>
    <% end %>
  </div>
<% end %>
