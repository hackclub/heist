<% content_for :title, "The Heist — 1,000 hours. One weekend." %>
<% content_for :hide_default_chrome, true %>

<div class="heist-landing" data-controller="landing">
  <div class="heist-landing__grid" aria-hidden="true"></div>
  <%= image_tag "landing/dark-layer.png", class: "heist-landing__ellipse", alt: "", "aria-hidden": true %>

  <%# link_to "LOG IN", signin_path, class: "heist-btn heist-btn--login" %>

  <nav data-landing-target="nav" class="heist-scroll-nav">
    <button data-landing-target="navItem" data-action="click->landing#open" data-section="how-it-works" class="heist-scroll-nav__btn">HOW IT WORKS</button>
    <button data-landing-target="navItem" data-action="click->landing#open" data-section="the-plan" class="heist-scroll-nav__btn">THE PLAN</button>
    <button data-landing-target="navItem" data-action="click->landing#open" data-section="faqs" class="heist-scroll-nav__btn">FAQS</button>
    <button data-landing-target="navItem" data-action="click->landing#open" data-section="credits" class="heist-scroll-nav__btn">CREDITS</button>
  </nav>

  <div class="heist-landing__inner">
    <section class="heist-hero">
      <%= image_tag "landing/hero-bracket.svg", class: "heist-hero__bracket", alt: "", "aria-hidden": true %>

      <h1 class="heist-title">
        <span class="visually-hidden">THE HEIST</span>
        <%= image_tag "landing/heist-title.png", class: "heist-title__img", alt: "", "aria-hidden": true %>
        <%= image_tag "landing/heist-cursor.png", class: "heist-title__cursor", alt: "", "aria-hidden": true %>
      </h1>

      <p class="heist-tagline">
        <span class="heist-tagline__accent">Together,</span> 1,000 hours.<br>
        <span class="heist-tagline__accent">Every</span> weekend.<br>
        Join the <span class="heist-tagline__accent">operation</span>.
      </p>

      <%= form_with url: rsvps_path, method: :post, class: "heist-join",
                    data: { turbo: false } do |f| %>
        <%= f.email_field :email,
              placeholder: "email@email.com",
              autocomplete: "email",
              required: true,
              class: "heist-join__input",
              "aria-label": "Email" %>
        <%= f.submit "RSVP", class: "heist-btn heist-btn--join" %>
      <% end %>

      <% if params[:rsvp] == "ok" %>
        <p class="heist-flash heist-flash--ok" role="status">You're in. We'll send the details when the heist begins.</p>
      <% elsif params[:rsvp] == "error" %>
        <p class="heist-flash heist-flash--error" role="alert"><%= params[:message].presence || "Couldn't record your RSVP — check the email and try again." %></p>
      <% end %>
    </section>

    <aside class="heist-crts">
      <div class="heist-crt heist-crt--counter" role="status" aria-live="polite">
        <%= image_tag "landing/crt1.png", class: "heist-crt__img", alt: "", "aria-hidden": true %>
        <p class="heist-crt__counter-text">
          <span class="heist-crt__counter-line">
            <span class="heist-crt__counter-number"><%= @active_hackers %></span>
            people <span class="heist-crt__counter-accent">hacking</span>
          </span>
          <span class="heist-crt__counter-big">right now</span>
        </p>
      </div>

      <div class="heist-crt heist-crt--scene">
        <%= image_tag "landing/crt2.png", class: "heist-crt__img", alt: "", "aria-hidden": true %>
      </div>

      <div class="heist-crt heist-crt--stream"
           data-controller="<%= @stream_live ? "" : "countdown" %>"
           <% unless @stream_live %>data-countdown-target-value="<%= @stream_starts_at.iso8601 %>"<% end %>>
        <%= image_tag "landing/crt3.png", class: "heist-crt__img", alt: "", "aria-hidden": true %>
        <% if @stream_live %>
          <iframe class="heist-crt__embed"
                  src="<%= @stream_embed_url %>"
                  title="The Heist live stream"
                  allow="autoplay; encrypted-media; picture-in-picture"
                  allowfullscreen></iframe>
        <% else %>
          <div class="heist-crt__stream-label">
            <span class="heist-crt__stream-dot" aria-hidden="true"></span>
            STREAM
          </div>
          <div class="heist-crt__timer" aria-label="Time until stream starts">
            <span data-countdown-target="days">--</span>:<span data-countdown-target="hours">--</span>:<span data-countdown-target="minutes">--</span>:<span data-countdown-target="seconds">--</span>
          </div>
        <% end %>
      </div>
    </aside>
  </div>

  <div data-landing-target="overlay" data-action="click->landing#closeOnBackdrop" class="heist-modal-overlay">
    <div class="heist-modal-panel">
      <h2 class="heist-modal-title">HOW IT WORKS</h2>
    </div>
  </div>

  <div data-landing-target="overlay" data-action="click->landing#closeOnBackdrop" class="heist-modal-overlay">
    <div class="heist-plan">
      <div class="heist-plan__topbar">
        <span class="heist-plan__subtitle">Stream Schedule</span>
      </div>
      <div class="heist-plan__title-row">
        <div class="heist-plan__title-line"></div>
        <div class="heist-plan__title-group">
          <span class="heist-plan__the">THE</span>
          <span class="heist-plan__title">PLAN</span>
        </div>
        <div class="heist-plan__title-line"></div>
      </div>
      <div class="heist-plan__days-header">
        <div class="heist-plan__time-spacer"></div>
        <div class="heist-plan__day">SATURDAY</div>
        <div class="heist-plan__day">SUNDAY</div>
      </div>
      <div class="heist-plan__hline"></div>
      <div class="heist-plan__grid">
        <div class="heist-plan__times">
          <% %w[1200 1300 1400 1500 1600].each do |time| %>
            <div class="heist-plan__time">
              <%= time %>
              <div class="heist-plan__tick"></div>
            </div>
          <% end %>
        </div>
        <div class="heist-plan__col-sat"></div>
        <div class="heist-plan__vline"></div>
        <div class="heist-plan__col-sun"></div>
      </div>
    </div>
  </div>

  <div data-landing-target="overlay" data-action="click->landing#closeOnBackdrop" class="heist-modal-overlay">
    <div class="heist-modal-panel">
      <h2 class="heist-modal-title">FAQS</h2>
    </div>
  </div>

  <div data-landing-target="overlay" data-action="click->landing#closeOnBackdrop" class="heist-modal-overlay">
    <div class="heist-modal-panel">
      <h2 class="heist-modal-title">CREDITS</h2>
    </div>
  </div>
</div>

<style>

  .heist-landing {
    --heist-bg: #0E1A10;
    --heist-bg-2: #0A1309;
    --heist-grid: rgba(90, 180, 96, 0.08);
    --heist-lime: #C5F187;
    --heist-lime-soft: #DCFCAE;
    --heist-green: #6BC96C;
    --heist-amber: #B5A251;
    --heist-ink: #14251C;

    position: relative;
    min-height: 100vh;
    color: var(--heist-green);
    /*background: radial-gradient(ellipse at 70% 50%, #13301C 0%, var(--heist-bg) 55%, var(--heist-bg-2) 100%);*/
    font-family: "ModeSeven", ui-monospace, "SFMono-Regular", Menlo, monospace;
    overflow-x: hidden;

    height: 100vh;
    width: 100vw;
    background-color: #101c13;
    background-image:
            repeating-linear-gradient(
                    to right,
                    transparent,
                    transparent 119px,
                    rgba(180,255,120,0.18) 119px,
                    rgba(180,255,120,0.18) 121px,
                    transparent 121px
            ),
            repeating-linear-gradient(
                    to bottom,
                    transparent,
                    transparent 119px,
                    rgba(180,255,120,0.18) 119px,
                    rgba(180,255,120,0.18) 121px,
                    transparent 121px
            ),
            repeating-linear-gradient(
                    to right,
                    transparent,
                    transparent 39px,
                    rgba(180,255,120,0.10) 39px,
                    rgba(180,255,120,0.10) 41px,
                    transparent 41px,
                    transparent 79px,
                    rgba(180,255,120,0.10) 79px,
                    rgba(180,255,120,0.10) 81px,
                    transparent 81px,
                    transparent 120px
            ),
            repeating-linear-gradient(
                    to bottom,
                    transparent,
                    transparent 39px,
                    rgba(180,255,120,0.10) 39px,
                    rgba(180,255,120,0.10) 41px,
                    transparent 41px,
                    transparent 79px,
                    rgba(180,255,120,0.10) 79px,
                    rgba(180,255,120,0.10) 81px,
                    transparent 81px,
                    transparent 120px
            ),
            repeating-linear-gradient(
                    to right,
                    rgba(80, 120, 80, 0.18) 0px,
                    rgba(80, 120, 80, 0.18) 2px,
                    transparent 2px,
                    transparent 120px
            ),
            repeating-linear-gradient(
                    to bottom,
                    rgba(80, 120, 80, 0.18) 0px,
                    rgba(80, 120, 80, 0.18) 2px,
                    transparent 2px,
                    transparent 120px
            ),
            radial-gradient(
                    ellipse at 35% 50%,
                    rgba(180, 255, 120, 0.13) 0%,
                    rgba(0,0,0,0.0) 60%
            );
    background-size:
            200px 200px,
            200px 200px,
            40px 40px,
            40px 40px,
            200px 200px,
            200px 200px,
            100% 100%;
  }

  .heist-landing img {
    -webkit-user-drag: none;
    user-select: none;
    pointer-events: none;
  }

  .heist-landing__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--heist-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--heist-grid) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .heist-landing__ellipse {
    position: absolute;
    top: 10%;
    right: 0;
    width: 45%;
    max-width: 600px;
    height: auto;
    pointer-events: none;
    z-index: 0;
    opacity: 0.75;
  }

  .heist-landing__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 1.25rem 3rem;
  }

  @media (min-width: 900px) {
    .heist-landing__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      align-items: center;
      padding: 5rem 2.5rem;
    }
  }

  .heist-btn {
    display: inline-block;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: transform 120ms ease, filter 120ms ease;
  }

  .heist-btn:hover { filter: brightness(1.1); }
  .heist-btn:active { transform: translateY(1px); }

  .heist-btn--login {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    padding: 0.7rem 2.4rem;
    font-size: 0.85rem;
    background: var(--heist-amber);
    color: var(--heist-ink);
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(211, 159, 59, 0.25), 0 0 18px rgba(211, 159, 59, 0.35);
    z-index: 5;
  }

  @media (min-width: 900px) {
    .heist-btn--login {
      top: 2rem;
      right: 2rem;
      padding: 0.8rem 3rem;
      font-size: 0.95rem;
    }
  }

  .heist-hero {
    position: relative;
    padding: 2rem 0 0;
    min-width: 0;
  }

  .heist-hero__bracket {
    position: absolute;
    top: -1.5rem;
    left: -1rem;
    width: clamp(10rem, 22vw, 17rem);
    height: auto;
    pointer-events: none;
    filter: drop-shadow(0 0 8px rgba(171, 221, 100, 0.45));
  }

  @media (min-width: 900px) {
    .heist-hero__bracket {
      top: -2.5rem;
      left: -2.25rem;
    }
  }

  .heist-title {
    margin: 0;
    line-height: 0;
    display: flex;
    align-items: flex-end;
    gap: 0;
    width: clamp(24rem, 62vw, 48rem);
    max-width: 100%;
    filter: drop-shadow(0 0 8px rgba(200, 255, 0, 0.2));
  }

  .heist-title__img {
    display: block;
    width: 74.75%;
    height: auto;
    margin: 0;
  }

  .heist-title__cursor {
    display: block;
    width: 25.25%;
    height: auto;
    margin: 0;
    animation: heist-blink 1.1s steps(1) infinite;
  }

  @keyframes heist-blink { 50% { opacity: 0; } }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .heist-tagline {
    margin: 1.75rem 0 2rem;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: clamp(1.75rem, 3.8vw, 2.5rem);
    line-height: 1.1;
    color: var(--heist-green);
    text-shadow: 0 0 6px currentColor;
  }

  .heist-tagline__accent {
    color: var(--heist-amber);
    text-shadow: 0 0 6px currentColor;
  }

  .heist-flash {
    max-width: 30rem;
    margin: 1rem 0 0;
    padding: 0.6rem 0.9rem;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  .heist-flash--ok {
    color: var(--heist-lime);
    border-left: 2px solid var(--heist-lime);
    background: rgba(197, 241, 135, 0.08);
  }

  .heist-flash--error {
    color: var(--heist-amber);
    border-left: 2px solid var(--heist-amber);
    background: rgba(211, 159, 59, 0.08);
  }

  .heist-join {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    max-width: 30rem;
    padding: 0.45rem;
    border: 2px solid var(--heist-lime-soft);
    border-radius: 3px;
    background: rgba(220, 252, 174, 0.08);
    box-shadow: 0 0 0 1px rgba(220, 252, 174, 0.18), 0 0 24px rgba(220, 252, 174, 0.22);
  }

  .heist-join__input {
    flex: 1;
    min-width: 0;
    padding: 0.4rem 0.9rem;
    border: none;
    outline: none;
    background: transparent;
    color: var(--heist-lime);
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 1.55rem;
    letter-spacing: 0.02em;
  }

  .heist-join__input::placeholder {
    color: rgba(197, 241, 135, 0.55);
  }

  .heist-btn--join {
    padding: 0.2rem 1.5rem;
    background: var(--heist-amber);
    color: var(--heist-ink);
    border: 0;
    border-radius: 2px;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 1.2rem;
    box-shadow: 0 0 12px rgba(211, 159, 59, 0.35);
  }

  .heist-crts {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 0;
    align-items: center;
    justify-items: center;
    margin-top: 2rem;
  }

  @media (min-width: 900px) {
    .heist-crts { margin-top: 4rem; }
  }

  .heist-crt {
    position: relative;
    width: 150%;
    margin: -25% -25% -25% -25%;
  }

  .heist-crt--counter {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
  }

  .heist-crt--scene {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }

  .heist-crt--stream {
    grid-column: 1 / 3;
    grid-row: 2 / 3;
    width: 125%;
    margin: -14% -12.5% -12.5% -12.5%;
  }

  .heist-crt__img {
    display: block;
    width: 100%;
    height: auto;
  }

  .heist-crt__counter-text {
    position: absolute;
    top: 34%;
    left: 31%;
    right: 31%;
    bottom: 38%;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    font-size: clamp(0.65rem, 1.1vw, 1rem);
    line-height: 1.05;
    color: var(--heist-green);
    text-shadow: 0 0 6px rgba(194, 246, 120, 0.55);
    z-index: 2;
    pointer-events: none;
  }

  .heist-crt__counter-line {
    white-space: nowrap;
  }

  .heist-crt__counter-number {
    color: var(--heist-yellow);
    text-shadow: 0 0 8px rgba(225, 193, 95, 0.55);
  }

  .heist-crt__counter-accent {
    color: var(--heist-amber);
    text-shadow: 0 0 6px rgba(211, 159, 59, 0.45);
  }

  .heist-crt__counter-big {
    font-size: 1.6em;
    line-height: 1;
    margin-top: 0.15em;
  }

  .heist-crt__stream-label {
    position: absolute;
    top: 27%;
    left: 23%;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: clamp(0.85rem, 1.6vw, 1.2rem);
    letter-spacing: 0.08em;
    color: var(--heist-amber);
    text-shadow: 0 0 6px rgba(211, 159, 59, 0.5);
    z-index: 2;
  }

  .heist-crt__stream-dot {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--heist-amber);
    box-shadow: 0 0 10px var(--heist-amber);
    animation: heist-pulse 1.8s steps(1) infinite;
  }

  @keyframes heist-pulse {
    0%, 78% { opacity: 1; }
    80%, 100% { opacity: 0.12; }
  }

  .heist-crt__timer {
    position: absolute;
    bottom: 27%;
    right: 22%;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: clamp(1rem, 2.2vw, 1.75rem);
    letter-spacing: 0.12em;
    color: var(--heist-green);
    text-shadow: 0 0 8px rgba(194, 246, 120, 0.6);
    z-index: 2;
  }

  .heist-crt__embed {
    position: absolute;
    top: 20%;
    left: 20%;
    right: 20%;
    bottom: 20%;
    width: 60%;
    height: 60%;
    border: 0;
    z-index: 2;
  }

  @media (max-width: 640px) {
    .heist-crts { gap: 0.5rem; }
    .heist-crt--scene { transform: translateX(-10%) scale(0.95); }
  }

  @media (max-width: 899px) {
    .heist-landing__inner { padding-left: 0.75rem; padding-right: 0.75rem; }
    .heist-title { width: 100%; max-width: 48rem; }
  }

  /* Scroll nav */
  .heist-scroll-nav {
    position: fixed;
    left: 5rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    visibility: hidden;
    z-index: 60;
  }

  .heist-scroll-nav__btn {
    font-family: "ModeSeven", ui-monospace, "SFMono-Regular", Menlo, monospace;
    color: var(--heist-lime);
    font-size: 2rem;
    white-space: nowrap;
    letter-spacing: -0.05em;
    text-shadow: 0 0 6px currentColor;
    background: none;
    border: none;
    padding: 0;
    text-align: left;
    cursor: pointer;
    transition: color 0.15s;
    font-style: italic;
  }

  .heist-scroll-nav__btn:hover { color: var(--heist-amber); }

  .heist-scroll-nav__btn.nav-active {
    color: var(--heist-amber);
    text-shadow: 0 0 8px var(--heist-amber);
  }

  /* Modal overlays */
  .heist-modal-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    z-index: 50;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .heist-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .heist-modal-panel {
    background-color: #4B6C42;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.07) 1px, transparent 1px);
    background-size: 40px 40px;
    padding: 2rem;
    width: 48rem;
  }

  .heist-modal-title {
    font-family: "ModeSeven", ui-monospace, monospace;
    color: #fff;
    font-size: 2.25rem;
    margin: 0;
    text-shadow: 0 0 6px currentColor;
  }

  .heist-plan__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    border-bottom: 1px dashed rgba(255,255,255,0.5);
    padding-bottom: 0.75rem;
  }

  .heist-plan__title-group { display: flex; align-items: baseline; gap: 0.75rem; }

  .heist-plan__the {
    font-family: "ModeSeven", ui-monospace, monospace;
    color: #fff;
    font-size: 1.5rem;
  }

  .heist-plan__title {
    font-family: "ModeSeven", ui-monospace, monospace;
    color: #fff;
    font-size: 2.25rem;
    font-weight: bold;
    font-style: italic;
    letter-spacing: 0.1em;
    text-shadow: 0 0 10px rgba(255,255,255,0.8), 0 0 20px rgba(255,255,255,0.4);
  }

  .heist-plan__subtitle {
    font-family: "ModeSeven", ui-monospace, monospace;
    color: rgba(255,255,255,0.8);
    font-size: 0.875rem;
  }

  .heist-plan__days-header { display: flex; }
  .heist-plan__time-spacer { width: 4rem; flex-shrink: 0; }
  .heist-plan__days { display: flex; flex: 1; }

  .heist-plan__day {
    flex: 1;
    text-align: center;
    font-family: "ModeSeven", ui-monospace, monospace;
    color: #fff;
    font-size: 1.25rem;
    padding-bottom: 0.75rem;
  }

  .heist-plan__grid {
    display: flex;
    border-top: 1px dashed rgba(255,255,255,0.5);
  }

  .heist-plan__times {
    width: 4rem;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0;
    gap: 2rem;
    margin-top: 1rem;
  }

  .heist-plan__time {
    font-family: "ModeSeven", ui-monospace, monospace;
    color: #fff;
    font-size: 0.875rem;
