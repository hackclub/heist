<% content_for :title, "The Heist — 1,000 hours. One weekend." %>
<% content_for :hide_default_chrome, true %>

<div class="heist-landing">
  <div class="heist-landing__grid" aria-hidden="true"></div>
  <div class="heist-landing__glow" aria-hidden="true"></div>

  <%= link_to "LOG IN", signin_path, class: "heist-btn heist-btn--login" %>

  <div class="heist-landing__inner">
    <section class="heist-hero">
      <%= image_tag "landing/hero-bracket.svg", class: "heist-hero__bracket", alt: "", "aria-hidden": true %>

      <h1 class="heist-title">
        <span class="visually-hidden">THE HEIST</span>
        <%= image_tag "landing/heist-title.png", class: "heist-title__img", alt: "", "aria-hidden": true %>
        <%= image_tag "landing/heist-cursor.png", class: "heist-title__cursor", alt: "", "aria-hidden": true %>
      </h1>

      <p class="heist-tagline">
        <span class="heist-tagline__accent">1,000</span> hours.<br>
        <span class="heist-tagline__accent">One</span> weekend.<br>
        Join the <span class="heist-tagline__accent">operation</span>.
      </p>

      <%= form_with url: signin_path, method: :get, local: true, class: "heist-join" do |f| %>
        <%= f.email_field :email,
              placeholder: "email@email.com",
              autocomplete: "email",
              class: "heist-join__input",
              "aria-label": "Email" %>
        <%= f.submit "JOIN", class: "heist-btn heist-btn--join" %>
      <% end %>
    </section>

    <aside class="heist-crts">
      <div class="heist-crt heist-crt--counter" role="status" aria-live="polite">
        <div class="heist-crt__screen" style="background-image: url('<%= image_path "landing/screen-texture.png" %>');">
          <p class="heist-crt__counter-text">
            <span class="heist-crt__counter-number"><%= @active_hackers %></span>
            people <span class="heist-crt__counter-accent">hacking</span><br>right now
          </p>
        </div>
        <%= image_tag "landing/crt1-bezel.svg", class: "heist-crt__bezel", alt: "", "aria-hidden": true %>
      </div>

      <div class="heist-crt heist-crt--scene">
        <div class="heist-crt__screen heist-crt__screen--scene">
          <%= image_tag "landing/pixel-scene.png", class: "heist-crt__art", alt: "", "aria-hidden": true %>
        </div>
        <%= image_tag "landing/crt2-bezel.svg", class: "heist-crt__bezel", alt: "", "aria-hidden": true %>
      </div>

      <div class="heist-crt heist-crt--stream"
           data-controller="<%= @stream_live ? "" : "countdown" %>"
           <% unless @stream_live %>data-countdown-target-value="<%= @stream_starts_at.iso8601 %>"<% end %>>
        <div class="heist-crt__screen heist-crt__screen--stream" style="background-image: url('<%= image_path "landing/screen-texture.png" %>');">
          <% if @stream_live %>
            <iframe class="heist-crt__embed"
                    src="<%= @stream_embed_url %>"
                    title="The Heist live stream"
                    allow="autoplay; encrypted-media; picture-in-picture"
                    allowfullscreen></iframe>
          <% else %>
            <div class="heist-crt__stream-label">
              <span class="heist-crt__stream-dot" aria-hidden="true"></span>
              STREAM
            </div>
            <div class="heist-crt__timer" aria-label="Time until stream starts">
              <span data-countdown-target="days">--</span>:<span data-countdown-target="hours">--</span>:<span data-countdown-target="minutes">--</span>:<span data-countdown-target="seconds">--</span>
            </div>
          <% end %>
        </div>
        <%= image_tag "landing/crt3-bezel.svg", class: "heist-crt__bezel", alt: "", "aria-hidden": true %>
      </div>
    </aside>
  </div>
</div>

<style>
  .heist-landing {
    --heist-bg: #0E1A10;
    --heist-bg-2: #0A1309;
    --heist-grid: rgba(90, 180, 96, 0.08);
    --heist-lime: #C5F187;
    --heist-lime-soft: #DCFCAE;
    --heist-green: #6BC96C;
    --heist-amber: #D39F3B;
    --heist-ink: #14251C;

    position: relative;
    min-height: 100vh;
    color: var(--heist-green);
    background: radial-gradient(ellipse at 70% 50%, #13301C 0%, var(--heist-bg) 55%, var(--heist-bg-2) 100%);
    font-family: "ModeSeven", ui-monospace, "SFMono-Regular", Menlo, monospace;
    overflow-x: hidden;
  }

  .heist-landing__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--heist-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--heist-grid) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .heist-landing__glow {
    position: absolute;
    top: -10%;
    right: -20%;
    width: 70%;
    height: 110%;
    background: radial-gradient(ellipse at center, rgba(110, 233, 110, 0.18) 0%, transparent 65%);
    pointer-events: none;
    filter: blur(10px);
  }

  .heist-landing__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.25rem 3rem;
  }

  @media (min-width: 900px) {
    .heist-landing__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      align-items: center;
      padding: 5rem 2.5rem;
    }
  }

  .heist-btn {
    display: inline-block;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: transform 120ms ease, filter 120ms ease;
  }

  .heist-btn:hover { filter: brightness(1.1); }
  .heist-btn:active { transform: translateY(1px); }

  .heist-btn--login {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    padding: 0.85rem 1.4rem;
    background: var(--heist-amber);
    color: var(--heist-ink);
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(211, 159, 59, 0.25), 0 0 18px rgba(211, 159, 59, 0.35);
    z-index: 5;
  }

  @media (min-width: 900px) {
    .heist-btn--login {
      top: 2rem;
      right: 2rem;
      padding: 1rem 1.6rem;
      font-size: 0.85rem;
    }
  }

  .heist-hero {
    position: relative;
    padding: 2rem 0 0;
    min-width: 0;
  }

  .heist-hero__bracket {
    position: absolute;
    top: -1.5rem;
    left: -1rem;
    width: clamp(10rem, 22vw, 17rem);
    height: auto;
    pointer-events: none;
    opacity: 0.85;
    filter: drop-shadow(0 0 8px rgba(171, 221, 100, 0.45));
  }

  @media (min-width: 900px) {
    .heist-hero__bracket {
      top: -2.5rem;
      left: -2.25rem;
    }
  }

  .heist-title {
    margin: 0;
    line-height: 0;
    display: flex;
    align-items: flex-end;
    gap: 0;
    width: clamp(24rem, 62vw, 48rem);
    max-width: 100%;
  }

  .heist-title__img {
    display: block;
    width: 74.75%;
    height: auto;
  }

  .heist-title__cursor {
    display: block;
    width: 25.25%;
    height: auto;
    animation: heist-blink 1.1s steps(1) infinite;
  }

  @keyframes heist-blink { 50% { opacity: 0; } }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .heist-tagline {
    margin: 1.75rem 0 2rem;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: clamp(1.75rem, 3.8vw, 2.5rem);
    line-height: 1.1;
    color: var(--heist-green);
    text-shadow: 0 0 10px rgba(107, 201, 108, 0.25);
  }

  .heist-tagline__accent {
    color: var(--heist-amber);
    text-shadow: 0 0 10px rgba(211, 159, 59, 0.3);
  }

  .heist-join {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    max-width: 28rem;
    padding: 0.45rem;
    border: 3px solid var(--heist-lime-soft);
    border-radius: 3px;
    background: rgba(220, 252, 174, 0.08);
    box-shadow: 0 0 0 1px rgba(220, 252, 174, 0.18), 0 0 24px rgba(220, 252, 174, 0.22);
  }

  .heist-join__input {
    flex: 1;
    min-width: 0;
    padding: 0.4rem 0.75rem;
    border: none;
    outline: none;
    background: transparent;
    color: var(--heist-lime);
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 1.5rem;
    letter-spacing: 0.02em;
  }

  .heist-join__input::placeholder {
    color: rgba(197, 241, 135, 0.55);
  }

  .heist-btn--join {
    padding: 0.5rem 1.1rem;
    background: var(--heist-amber);
    color: var(--heist-ink);
    border: 0;
    border-radius: 2px;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: 0.7rem;
    box-shadow: 0 0 12px rgba(211, 159, 59, 0.35);
  }

  .heist-crts {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem 1rem;
    align-items: center;
    justify-items: center;
    margin-top: 3rem;
  }

  @media (min-width: 900px) {
    .heist-crts { margin-top: 6rem; }
  }

  .heist-crt {
    position: relative;
    width: 100%;
    filter: drop-shadow(0 18px 24px rgba(0, 0, 0, 0.5));
  }

  .heist-crt--counter {
    grid-column: 1 / 2;
    grid-row: 1 / 2;
    aspect-ratio: 247 / 166;
    transform: skewX(-4deg) rotate(-1.5deg);
  }

  .heist-crt--scene {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
    aspect-ratio: 301.76 / 204;
    transform: skewX(2.5deg);
  }

  .heist-crt--stream {
    grid-column: 1 / 3;
    grid-row: 2 / 3;
    aspect-ratio: 524 / 332.945;
    max-width: 95%;
  }

  .heist-crt__bezel {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }

  .heist-crt__screen {
    position: absolute;
    top: 5.7%;
    left: 4.9%;
    right: 4.5%;
    bottom: 8.2%;
    overflow: hidden;
    border-radius: 10% / 16%;
    background-color: #1F4624;
    background-size: cover;
    background-position: center;
    background-blend-mode: multiply;
    box-shadow:
      inset 0 0 60px rgba(0, 0, 0, 0.6),
      inset 0 0 14px rgba(0, 0, 0, 0.7);
    color: var(--heist-green);
    font-family: "ModeSeven", ui-monospace, monospace;
    z-index: 1;
  }

  .heist-crt--scene .heist-crt__screen {
    top: 5.75%;
    left: 4.85%;
    right: 4.47%;
    bottom: 7.63%;
    border-radius: 8% / 14%;
  }

  .heist-crt--stream .heist-crt__screen {
    top: 5.81%;
    left: 4.79%;
    right: 4.39%;
    bottom: 6.73%;
    border-radius: 5% / 9%;
  }

  .heist-crt__screen::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(90, 180, 100, 0.18) 0%, transparent 65%);
    pointer-events: none;
  }

  .heist-crt__screen::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.035) 0,
      rgba(255, 255, 255, 0.035) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
    animation: heist-scan 8s linear infinite;
  }

  @keyframes heist-scan {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }

  .heist-crt__counter-text {
    position: absolute;
    inset: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8% 10%;
    font-size: clamp(1rem, 2.2vw, 1.7rem);
    line-height: 1.05;
    color: var(--heist-green);
    text-shadow: 0 0 6px rgba(194, 246, 120, 0.55);
    z-index: 2;
  }

  .heist-crt__counter-number {
    color: var(--heist-yellow);
    text-shadow: 0 0 8px rgba(225, 193, 95, 0.55);
  }

  .heist-crt__counter-accent {
    color: var(--heist-yellow-soft);
  }

  .heist-crt__art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    z-index: 1;
  }

  .heist-crt__stream-label {
    position: absolute;
    top: 6%;
    left: 5%;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: clamp(0.6rem, 1.1vw, 0.85rem);
    letter-spacing: 0.08em;
    color: var(--heist-yellow);
    text-shadow: 0 0 6px rgba(225, 193, 95, 0.5);
    z-index: 2;
  }

  .heist-crt__stream-dot {
    display: inline-block;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--heist-yellow);
    box-shadow: 0 0 8px var(--heist-yellow);
    animation: heist-pulse 1.6s ease-in-out infinite;
  }

  @keyframes heist-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  .heist-crt__timer {
    position: absolute;
    bottom: 6%;
    right: 6%;
    font-family: "ModeSeven", ui-monospace, monospace;
    font-size: clamp(1rem, 2.2vw, 1.75rem);
    letter-spacing: 0.12em;
    color: var(--heist-green);
    text-shadow: 0 0 8px rgba(194, 246, 120, 0.6);
    z-index: 2;
  }

  .heist-crt__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    z-index: 2;
  }

  @media (max-width: 640px) {
    .heist-crt--counter { transform: none; }
    .heist-crt--scene { transform: none; }
    .heist-crts { gap: 0.85rem; }
  }

  @media (max-width: 899px) {
    .heist-landing__inner { padding-left: 0.75rem; padding-right: 0.75rem; }
    .heist-title { width: 100%; max-width: 48rem; }
  }
</style>
