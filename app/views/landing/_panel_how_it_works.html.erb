<article class="heist-overlay__section heist-how-it-works"
         data-section="how"
         data-overlay-panel-target="section"
         hidden>
  <figure class="heist-how-it-works__plate">
    <%= image_tag "landing/how-it-works.png",
          class: "heist-how-it-works__art",
          alt: "Handwritten blueprint of the heist: step 1 join the stream, step 2 start a project, step 3 hit 1000 hours together, step 4 steal the prizes." %>
  </figure>

  <ol class="heist-how-it-works__steps visually-hidden">
    <li>
      <strong>Join the stream.</strong>
      Tune into the live broadcast throughout the weekend.
    </li>
    <li>
      <strong>Start a project.</strong>
      Make anything you want, hardware or software.
    </li>
    <li>
      <strong>Hit 1,000 hours together.</strong>
      Everyone's Hackatime rolls up to the shared goal.
    </li>
    <li>
      <strong>Steal the prizes.</strong>
      Cross the line and the crew unlocks grants and loot.
    </li>
  </ol>
</article>
