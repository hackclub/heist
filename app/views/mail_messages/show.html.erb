<% content_for :title, "TRANSMISSION — The Heist" %>
<% content_for :hide_default_chrome, true %>

<div class="heist-mail">
  <header class="heist-mail__header">
    <%= link_to "← INBOX", mail_messages_path, class: "heist-mail__back" %>
    <span class="heist-mail__id">TRANSMISSION #<%= format("%04d", @mail_message.id % 10_000) %></span>
    <%= render "shared/heist_identity" %>
  </header>

  <%= render "shared/heist_sidebar", active: :inbox %>

  <main class="heist-mail__main">
    <article class="heist-mail__panel">
      <div class="heist-mail__meta">
        <dl>
          <dt>FROM</dt><dd>HEIST CONTROL</dd>
          <dt>KIND</dt><dd><%= @mail_message.kind %></dd>
          <dt>TIME</dt><dd><%= @mail_message.created_at.to_fs(:long) %></dd>
        </dl>
      </div>

      <h1 class="heist-mail__subject"><%= @mail_message.subject.upcase %></h1>

      <div class="heist-mail__body">
        <%= simple_format(@mail_message.body) %>
      </div>

      <% if @mail_message.mailable_type == "Ship" && (ship = @mail_message.mailable) %>
        <footer class="heist-mail__footer">
          <%= link_to "VIEW SHIP →", project_path(ship.project), class: "heist-mail__cta" %>
        </footer>
      <% end %>
    </article>
  </main>
</div>

<style>
  .heist-mail {
    --heist-bg: #0E1A10;
    --heist-grid: rgba(90, 180, 96, 0.08);
    --heist-lime: #C0F477;
    --heist-lime-soft: #DAFBAC;
    --heist-amber: #FFE572;
    --heist-amber-dim: #DBC45F;
    --heist-ink: #14251C;
    --heist-stripe-lime: repeating-linear-gradient(135deg, rgba(192, 244, 119, 0.14) 0 6px, transparent 6px 12px);

    position: relative;
    min-height: 100vh;
    color: var(--heist-lime);
    background-color: var(--heist-bg);
    background-image:
      linear-gradient(to right, var(--heist-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--heist-grid) 1px, transparent 1px);
    background-size: 44px 44px;
    font-family: "ModeSeven", ui-monospace, "SFMono-Regular", Menlo, monospace;
    display: grid;
    grid-template-columns: 75px minmax(0, 1fr);
    grid-template-rows: auto minmax(0, 1fr);
    grid-template-areas:
      "header header"
      "sidebar main";
    column-gap: 4px;
    row-gap: 4px;
    padding: 1.25rem;
    box-sizing: border-box;
  }

  .heist-mail::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgba(192, 244, 119, 0.04) 0,
      rgba(192, 244, 119, 0.04) 1px,
      transparent 1px,
      transparent 3px
    );
    z-index: 1;
  }

  .heist-mail > * { position: relative; z-index: 2; }

  .heist-mail__header {
    grid-area: header;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.25rem;
    border: 4px solid var(--heist-lime);
    background: var(--heist-stripe-lime), rgba(10, 19, 9, 0.7);
    box-shadow: 0 0 24px rgba(192, 244, 119, 0.2);
  }

  .heist-mail__back {
    color: var(--heist-lime);
    text-decoration: none;
    font-family: "Audiowide", "ModeSeven", monospace;
    letter-spacing: 0.08em;
    font-size: 16px;
  }

  .heist-mail__back:hover { color: var(--heist-amber); }

  .heist-mail__id {
    color: var(--heist-amber-dim);
    font-size: 14px;
    letter-spacing: 0.08em;
  }

  /* Main panel */
  .heist-mail__main {
    grid-area: main;
    overflow-y: auto;
  }

  .heist-mail__panel {
    border: 4px solid var(--heist-lime-soft);
    background: rgba(10, 19, 9, 0.7);
    padding: 1.5rem;
    max-width: 800px;
  }

  .heist-mail__meta {
    border-bottom: 2px dashed rgba(218, 251, 172, 0.3);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .heist-mail__meta dl {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 4px 1rem;
    margin: 0;
  }

  .heist-mail__meta dt {
    color: var(--heist-amber-dim);
    font-size: 12px;
    letter-spacing: 0.08em;
  }

  .heist-mail__meta dd {
    margin: 0;
    color: var(--heist-lime-soft);
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  .heist-mail__subject {
    font-family: "Blade Runner", "ModeSeven", ui-monospace, monospace;
    font-size: 32px;
    letter-spacing: 0.06em;
    color: var(--heist-amber);
    text-shadow: 0 0 10px rgba(255, 229, 114, 0.4);
    margin: 0 0 1rem 0;
  }

  .heist-mail__body {
    color: var(--heist-lime-soft);
    line-height: 1.7;
    font-size: 15px;
    border-left: 4px solid var(--heist-lime);
    padding-left: 1rem;
  }

  .heist-mail__body p { margin: 0 0 1rem; }
  .heist-mail__body p:last-child { margin-bottom: 0; }

  .heist-mail__footer {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 2px dashed rgba(218, 251, 172, 0.3);
  }

  .heist-mail__cta {
    display: inline-block;
    background: var(--heist-amber);
    color: var(--heist-ink);
    font-family: "Audiowide", "ModeSeven", monospace;
    padding: 0.65rem 1.25rem;
    text-decoration: none;
    letter-spacing: 0.08em;
    font-size: 15px;
    box-shadow: 0 0 16px rgba(255, 229, 114, 0.4);
  }

  .heist-mail__cta:hover { filter: brightness(1.1); }
</style>
