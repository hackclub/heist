<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Heist" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <style>
      @font-face { font-family: "Audiowide"; src: url("/static-assets/Audiowide-Regular.ttf") format("truetype"); font-display: swap; }
      @font-face { font-family: "ModeSeven"; src: url("/static-assets/Modeseven-L3n5.ttf") format("truetype"); font-display: swap; }
      @font-face { font-family: "Blade Runner"; src: url("/static-assets/BLADRMF_.TTF") format("truetype"); font-display: swap; }
    </style>

    <link rel="preload" as="font" type="font/ttf" href="/static-assets/Audiowide-Regular.ttf" crossorigin>
    <link rel="preload" as="font" type="font/ttf" href="/static-assets/Modeseven-L3n5.ttf" crossorigin>
    <link rel="preload" as="font" type="font/ttf" href="/static-assets/BLADRMF_.TTF" crossorigin>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="heist-body">
    <% if user_signed_in? %>
      <%= render "shared/heist_chrome" %>
    <% else %>
      <main class="heist-chrome heist-chrome--bare">
        <% if notice %><div class="heist-chrome__flash heist-chrome__flash--notice"><%= notice %></div><% end %>
        <% if alert %><div class="heist-chrome__flash heist-chrome__flash--alert"><%= alert %></div><% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>