<div class="heist-admin__page-header">
  <h1>
    <%= @user.display_name %>
    <% if @user.discarded? %>
      <span class="heist-admin__pill heist-admin__pill--rejected">DELETED <%= @user.discarded_at.strftime("%b %d, %Y") %></span>
    <% end %>
  </h1>
  <%= link_to "EDIT ROLES →", edit_admin_user_path(@user), class: "heist-admin__btn" %>
</div>

<div class="heist-admin__panel">
  <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
    <%= image_tag @user.avatar_url, class: "heist-identity__avatar", alt: "", style: "width: 80px; height: 80px;" %>
    <dl class="heist-admin__form-stack" style="flex: 1; margin: 0;">
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Email</dt>
        <dd><%= @user.email %></dd>
      </div>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Roles</dt>
        <dd>
          <% @user.roles.each do |role| %>
            <span class="heist-admin__pill"><%= role.upcase %></span>
          <% end %>
        </dd>
      </div>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Timezone</dt>
        <dd><%= @user.timezone %></dd>
      </div>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Joined</dt>
        <dd><%= @user.created_at.strftime("%B %d, %Y") %></dd>
      </div>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Banned</dt>
        <dd><%= @user.is_banned ? "Yes" : "No" %></dd>
      </div>
    </dl>
  </div>
</div>

<h2>Projects (<%= @projects.size %>)</h2>

<% if @projects.any? %>
  <table class="heist-admin__table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Ships</th>
        <th>Unlisted</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr>
          <td><%= link_to project.name, admin_project_path(project) %></td>
          <td><%= project.ships.size %></td>
          <td><%= project.is_unlisted ? "Yes" : "—" %></td>
          <td><%= project.created_at.strftime("%b %d, %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="heist-admin__table-empty">No projects yet.</p>
<% end %>
