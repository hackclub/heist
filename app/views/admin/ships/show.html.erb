<div class="heist-admin__page-header">
  <h1>SHIP #<%= @ship.id %></h1>
  <% if policy(@ship).update? %>
    <%= link_to "REVIEW →", edit_admin_ship_path(@ship), class: "heist-admin__btn" %>
  <% end %>
</div>

<p>For <%= link_to @ship.project.name, admin_project_path(@ship.project) %> by <%= link_to @ship.project.user.display_name, admin_user_path(@ship.project.user) %></p>

<div class="heist-admin__panel">
  <dl class="heist-admin__form-stack">
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Status</dt>
      <dd><span class="heist-admin__pill heist-admin__pill--<%= @ship.status %>"><%= @ship.status %></span></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Reviewer</dt>
      <dd><%= @ship.reviewer&.display_name || "—" %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Approved Seconds</dt>
      <dd><%= @ship.approved_seconds || "—" %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Created</dt>
      <dd><%= @ship.created_at.strftime("%B %d, %Y") %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Frozen Demo Link</dt>
      <dd><%= safe_url(@ship.frozen_demo_link) ? link_to(@ship.frozen_demo_link, safe_url(@ship.frozen_demo_link), target: "_blank", rel: "noopener") : "—" %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Frozen Repo Link</dt>
      <dd><%= safe_url(@ship.frozen_repo_link) ? link_to(@ship.frozen_repo_link, safe_url(@ship.frozen_repo_link), target: "_blank", rel: "noopener") : "—" %></dd>
    </div>
    <% if @ship.justification.present? %>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Justification</dt>
        <dd><%= @ship.justification %></dd>
      </div>
    <% end %>
    <% if @ship.feedback.present? %>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Feedback</dt>
        <dd><%= @ship.feedback %></dd>
      </div>
    <% end %>
  </dl>
</div>
