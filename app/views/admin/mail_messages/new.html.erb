<div class="heist-admin__page-header">
  <h1>COMPOSE MAIL</h1>
</div>

<div class="heist-admin__panel">
  <%= form_with url: admin_mail_messages_path, method: :post, local: true, class: "heist-admin__form-stack" do |f| %>
    <div class="heist-admin__form-field">
      <label style="display: flex; align-items: center; gap: 0.5rem; font-family: 'ModeSeven', monospace; text-transform: none; letter-spacing: 0; color: #DAFBAC;">
        <%= check_box_tag :broadcast, "1", false, style: "accent-color: #FFE572; width: 16px; height: 16px;" %>
        <span>Broadcast to all kept users</span>
      </label>
    </div>

    <div class="heist-admin__form-field">
      <%= label_tag :recipient_id, "Recipient" %>
      <%= select_tag :recipient_id,
            options_from_collection_for_select(@users, :id, :display_name),
            include_blank: "— Select a user —" %>
      <span class="heist-admin__hint">Ignored when broadcast is checked.</span>
    </div>

    <div class="heist-admin__form-field">
      <%= label_tag :subject %>
      <%= text_field_tag :subject, params[:subject], required: true %>
    </div>

    <div class="heist-admin__form-field">
      <%= label_tag :body %>
      <%= text_area_tag :body, params[:body], rows: 8 %>
    </div>

    <div class="heist-admin__btn-row">
      <%= f.submit "SEND", class: "heist-admin__btn" %>
      <%= link_to "CANCEL", admin_mail_messages_path, class: "heist-admin__btn heist-admin__btn--ghost" %>
    </div>
  <% end %>
</div>
