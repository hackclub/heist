<div class="heist-admin__page-header">
  <h1>PROJECTS</h1>
</div>

<%= form_with url: admin_projects_path, method: :get, class: "heist-admin__search" do |f| %>
  <%= f.search_field :query, value: params[:query], placeholder: "Search projects..." %>
  <%= f.submit "SEARCH", class: "heist-admin__btn heist-admin__btn--ghost" %>
<% end %>

<table class="heist-admin__table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Owner</th>
      <th>Ships</th>
      <th>Unlisted</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @projects.each do |project| %>
      <tr<% if project.discarded? %> style="opacity: 0.5"<% end %>>
        <td>
          <%= link_to project.name, admin_project_path(project) %>
          <% if project.discarded? %>
            <span class="heist-admin__pill heist-admin__pill--rejected">DELETED</span>
          <% end %>
        </td>
        <td><%= link_to project.user.display_name, admin_user_path(project.user) %></td>
        <td><%= project.ships.size %></td>
        <td><%= project.is_unlisted ? "Yes" : "—" %></td>
        <td><%= project.created_at.strftime("%b %d, %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%== pagy_nav(@pagy) %>
