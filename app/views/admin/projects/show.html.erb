<div class="heist-admin__page-header">
  <h1>
    <%= @project.name %>
    <% if @project.discarded? %>
      <span class="heist-admin__pill heist-admin__pill--rejected">DELETED <%= @project.discarded_at.strftime("%b %d, %Y") %></span>
    <% end %>
  </h1>
</div>

<p>Owned by <%= link_to @project.user.display_name, admin_user_path(@project.user) %></p>

<div class="heist-admin__panel">
  <dl class="heist-admin__form-stack">
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Unlisted</dt>
      <dd><%= @project.is_unlisted ? "Yes" : "No" %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Tags</dt>
      <dd><%= @project.tags.any? ? @project.tags.join(", ") : "—" %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Demo Link</dt>
      <dd><%= safe_url(@project.demo_link) ? link_to(@project.demo_link, safe_url(@project.demo_link), target: "_blank", rel: "noopener") : "—" %></dd>
    </div>
    <div class="heist-admin__form-field">
      <dt class="heist-admin__label">Repo Link</dt>
      <dd><%= safe_url(@project.repo_link) ? link_to(@project.repo_link, safe_url(@project.repo_link), target: "_blank", rel: "noopener") : "—" %></dd>
    </div>
    <% if @project.description.present? %>
      <div class="heist-admin__form-field">
        <dt class="heist-admin__label">Description</dt>
        <dd><%= @project.description %></dd>
      </div>
    <% end %>
  </dl>
</div>

<h2>Ships (<%= @ships.size %>)</h2>

<% if @ships.any? %>
  <table class="heist-admin__table">
    <thead>
      <tr>
        <th>Status</th>
        <th>Reviewer</th>
        <th>Approved Seconds</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @ships.each do |ship| %>
        <tr>
          <td><span class="heist-admin__pill heist-admin__pill--<%= ship.status %>"><%= ship.status %></span></td>
          <td><%= ship.reviewer&.display_name || "—" %></td>
          <td><%= ship.approved_seconds || "—" %></td>
          <td><%= ship.created_at.strftime("%b %d, %Y") %></td>
          <td><%= link_to "View →", admin_ship_path(ship) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="heist-admin__table-empty">No ships yet.</p>
<% end %>
